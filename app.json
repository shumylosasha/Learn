{
  "expo": {
    "name": "Business English Coach",
    "slug": "business-english-coach",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bizenglish",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bizenglish.coach",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "We use the microphone to record your spoken English so the AI can analyse it and give you feedback.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bizenglish.coach",
      "permissions": ["RECORD_AUDIO"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone to record your spoken English."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
